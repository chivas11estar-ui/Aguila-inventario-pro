{
  "rules": {
    "usuarios": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },
    "productos": {
      "$determinante": {
        // Solo el usuario con el determinante correcto puede leer/escribir
        ".read": "auth != null && root.child('usuarios').child(auth.uid).child('determinante').val() === $determinante",
        ".write": "auth != null && root.child('usuarios').child(auth.uid).child('determinante').val() === $determinante",
        
        "$codigoBarras": {
          // Validación simplificada para evitar bloqueos por tipos de datos secundarios
          ".validate": "newData.hasChildren(['nombre', 'codigoBarras', 'stockTotal'])",
          "stockTotal": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },
          "codigoBarras": {
            ".validate": "newData.isString()"
          },
          "piezasPorCaja": {
             ".validate": "newData.isNumber()"
          },
          "fechaActualizacion": {
             ".validate": "newData.isNumber()"
          }
        }
      }
    },
    "movimientos": {
      "$determinante": {
        ".read": "auth != null && root.child('usuarios').child(auth.uid).child('determinante').val() === $determinante",
        ".write": "auth != null && root.child('usuarios').child(auth.uid).child('determinante').val() === $determinante"
      }
    },
    "auditorias": {
      "$determinante": {
        ".read": "auth != null && root.child('usuarios').child(auth.uid).child('determinante').val() === $determinante",
        ".write": "auth != null && root.child('usuarios').child(auth.uid).child('determinante').val() === $determinante"
      }
    },
    // Denegar por defecto
    ".read": false,
    ".write": false
  }
}
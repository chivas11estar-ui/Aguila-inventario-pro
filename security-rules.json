{
  "rules": {

    "usuarios": {
      "$uid": {
        ".read":  "$uid === auth.uid",
        ".write": "$uid === auth.uid",

        "determinante": {
          ".validate": "newData.isString() && newData.val().matches(/^[A-Z0-9]{4,8}$/)"
        },

        "frasesIA": {
          ".read":  "$uid === auth.uid",
          ".write": "$uid === auth.uid"
        }
      }
    },

    "productos": {
      "$determinante": {
        ".read":  "auth != null && root.child('usuarios').child(auth.uid).child('determinante').val() === $determinante",
        ".write": "auth != null && root.child('usuarios').child(auth.uid).child('determinante').val() === $determinante",
        ".indexOn": ["nombre", "marca"],

        "$codigoBarras": {
          ".validate": "newData.hasChildren(['nombre', 'codigoBarras']) && (newData.hasChild('lotes') || newData.hasChild('stockTotal'))",

          "nombre":       { ".validate": "newData.isString()" },
          "codigoBarras": { ".validate": "newData.isString() && newData.val().length >= 8" },
          "stockTotal":   { ".validate": "newData.isNumber() && newData.val() >= 0" },
          "piezasPorCaja":{ ".validate": "newData.isNumber() && newData.val() > 0" },

          "lotes": {
            "$loteId": {
              ".indexOn": ["bodega", "fechaCaducidad"],
              "stock":  { ".validate": "newData.isNumber() && newData.val() >= 0" },
              "bodega": { ".validate": "newData.isString()" }
            }
          }
        }
      }
    },

    "movimientos": {
      "$determinante": {
        ".read":  "auth != null && root.child('usuarios').child(auth.uid).child('determinante').val() === $determinante",
        ".write": "auth != null && root.child('usuarios').child(auth.uid).child('determinante').val() === $determinante",
        ".indexOn": ["fecha"],

        "$movId": {
          ".validate": "newData.hasChildren(['tipo', 'productoCodigo', 'cajasMovidas', 'fecha'])",
          "tipo":  { ".validate": "newData.isString() && newData.val().matches(/^(entrada|salida|entrada_directa_anaquel)$/)" },
          "fecha": { ".validate": "newData.isNumber()" }
        }
      }
    },

    "auditorias": {
      "$determinante": {
        ".read":  "auth != null && root.child('usuarios').child(auth.uid).child('determinante').val() === $determinante",
        ".write": "auth != null && root.child('usuarios').child(auth.uid).child('determinante').val() === $determinante",
        ".indexOn": ["fecha"]
      }
    },

    ".read":  false,
    ".write": false
  }
}

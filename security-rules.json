{
  "rules": {
    "usuarios": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        
        // Permitir guardar frases de IA sin validar el perfil completo cada vez
        "frasesIA": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid"
        }
      }
    },
    "productos": {
      "$determinante": {
        ".read": "auth != null && root.child('usuarios').child(auth.uid).child('determinante').val() === $determinante",
        ".write": "auth != null && root.child('usuarios').child(auth.uid).child('determinante').val() === $determinante",
        
        "$codigoBarras": {
          ".validate": "newData.hasChildren(['nombre', 'codigoBarras', 'stockTotal'])",
          "stockTotal": {
            ".validate": "newData.isNumber() && newData.val() >= 0"
          },
          "piezasPorCaja": {
            ".validate": "newData.isNumber() && newData.val() > 0"
          },
          "codigoBarras": {
            ".validate": "newData.isString() && newData.val().length >= 8"
          }
        }
      }
    },
    "movimientos": {
      "$determinante": {
        ".read": "auth != null && root.child('usuarios').child(auth.uid).child('determinante').val() === $determinante",
        ".write": "auth != null && root.child('usuarios').child(auth.uid).child('determinante').val() === $determinante",
        
        // Optimización de consultas
        ".indexOn": ["fecha"],
        
        "$pushId": {
          ".validate": "newData.hasChildren(['tipo', 'productoCodigo', 'cajasMovidas', 'fecha'])"
        }
      }
    },
    "auditorias": {
      "$determinante": {
        ".read": "auth != null && root.child('usuarios').child(auth.uid).child('determinante').val() === $determinante",
        ".write": "auth != null && root.child('usuarios').child(auth.uid).child('determinante').val() === $determinante",
        
        // Optimización de consultas
        ".indexOn": ["fecha"]
      }
    },
    ".read": false,
    ".write": false
  }
}
{
  "rules": {
    ".read": false,
    ".write": false,
    "usuarios": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "productos": {
      "$determinante": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".indexOn": ["codigoBarras", "marca", "fechaActualizacion"]
      }
    },
    "catalogoProductos": {
      "$codigoBarras": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "movimientos": {
      "$determinante": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".indexOn": ["fecha", "tipo", "productoCodigo"]
      }
    },
    "auditorias": {
      "$determinante": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".indexOn": ["fecha", "productoCodigo"]
      }
    }
  }
}
